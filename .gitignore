# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
dist/
build/
coverage/
.env
.env.*
!.env.example
.npm
.eslintcache

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
env/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
pip-log.txt
.coverage
.coverage.*
htmlcov/

# Project-specific
*.json
*.txt
.claude/

# ui/ is a normal npm project; its package/tsconfig JSON files aren't secrets
!ui/package.json
!ui/package-lock.json
!ui/tsconfig.json
!ui/tsconfig.*.json
!ui/leancrypto/package.json
# ...and neither are its source-tree JSON files (test fixtures, etc.) --
# credential JSONs live only at the repo root, never under ui/src/.
!ui/src/**/*.json
*.tsbuildinfo
